{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=h3xboard.db"
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_OF_AT_LEAST_32_CHARACTERS",
