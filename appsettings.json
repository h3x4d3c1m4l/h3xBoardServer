{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=h3xboard.db"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Auth": {
    "SessionIdleTimeoutDays": 30,
    "AllowRegistration": true
  },
  "Server": {
    "Warning": "",
    "WebAppUrl": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Storage": {
    "Backend": "FileSystem",
    "MaxUploadBytes": 10485760,
    "FileSystem": {
      "RootPath": "storage-data"
    }
  },
  "Settings": {
    "MaxValueBytes": 16384,
    "MaxKeysPerUser": 256
  },
  "Sharing": {
    "SessionTtlSeconds": 180,
    "MaxViewersPerSession": 100,
    "MaxMessageBytes": 524288
  }
}
